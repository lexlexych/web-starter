# ─────────────────────────────────────────────────────────────────────────────
#  Пример переменных окружения.
#  НЕ редактируйте этот файл вручную — Claude создаст .env.local за вас,
#  когда вы выберете базу данных или интеграции в /app-init.
#  Файл .env.local не попадает в git (там хранятся ваши секретные ключи).
# ─────────────────────────────────────────────────────────────────────────────

# ── База данных Supabase (путь «приложение с данными») ──────────────────────────
# Публичные значения проекта (можно показывать в браузере):
# NEXT_PUBLIC_SUPABASE_URL=https://<ваш-проект>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Личный токен доступа Supabase — нужен только для автоматизации через Claude.
# Где взять: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Отправка писем на e-mail (интеграция) ──────────────────────────────────────
# Провайдер по умолчанию — Resend. Ключ: https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM="Моё приложение <onboarding@resend.dev>"

# ── Уведомления в Telegram (интеграция) ────────────────────────────────────────
# Бот создаётся у @BotFather, chat_id — у @userinfobot
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789

# ── Приём оплаты (интеграция) ──────────────────────────────────────────────────
# Провайдер по умолчанию — Stripe. Ключи: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
