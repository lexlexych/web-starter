{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm run dev)",
      "Bash(npm run dev *)",
      "Bash(npm run build)",
      "Bash(npm run start)",
      "Bash(npx *)",
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Bash(rm -rf *)",
      "Bash(git push *)"
    ]
  }
}
